<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--thread-count="3" parallel="tests"-->
<suite name="Interview demo Test Regression Suite" verbose="4" thread-count="4"
	parallel="tests">

	<listeners>
		<listener
			class-name="com.aventstack.chaintest.plugins.ChainTestListener">
		</listener>
		<listener
			class-name="testcom.qa.sauselabs.listners.TestAllureListener">
		</listener>
	</listeners>
	<test name="Login Page Test_chrome">
		<parameter name="browser" value="chrome" />
		<parameter name="browserversion" value="146.0" />
		<parameter name="testname" value="Login Page Test" />
		<classes>
			 <class name="testcom.qa.sauselabs.tests.LoginPageTest" />
		</classes>
	</test>
	<test name="Login Page Test_edge">
		<parameter name="browser" value="edge" />
		<parameter name="browserversion" value="146.0" />
		<parameter name="testname" value="Login Page Test" />
		<classes>
			 <class name="testcom.qa.sauselabs.tests.LoginPageTest" />
		</classes>
	</test>

</suite>
